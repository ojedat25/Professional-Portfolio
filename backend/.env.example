# Django
SECRET_KEY=replace-with-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated frontend origins allowed by CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Render auto-injects RENDER_EXTERNAL_HOSTNAME in production; leave unset locally

# Database: set DATABASE_URL (e.g. from Render) OR discrete Postgres variables below.
# If neither is set, SQLite is used (db.sqlite3).
# DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DBNAME

# DB_NAME=portfolio
# DB_USER=portfolio_user
# DB_PASSWORD=your-secure-password
# DB_HOST=127.0.0.1
# DB_PORT=5432

# Optional GitHub PAT for /user/repos (higher rate limits, private repos if scoped). Omit for public API only.
# GITHUB_TOKEN=
